:global(html),
:global(body) {
  margin: 0;
  padding: 0;
  overflow-x: hidden;
  overflow-y: auto;
  background: #eaf6fb;
}

:root {
  color-scheme: light;
}

.shell {
  min-height: 100svh;
  display: grid;
  place-items: start center;
  background: #eaf6fb;
  font-family:
    -apple-system,
    BlinkMacSystemFont,
    "Apple SD Gothic Neo",
    "Noto Sans KR",
    system-ui,
    sans-serif;
}

.hero {
  position: relative;
  width: min(100vw, 430px);
  min-height: 100svh;
  padding-bottom: 24px;
  color: #322f2a;
  background:
    radial-gradient(circle at 91% 13%, rgba(172, 145, 113, 0.24), transparent 20rem),
    radial-gradient(circle at 10% 88%, rgba(139, 72, 49, 0.06), transparent 16rem),
    linear-gradient(145deg, #f8f1e7 0%, #efe3d4 48%, #f9f6ef 100%);
  box-shadow: 0 24px 80px rgba(18, 56, 76, 0.08);
  isolation: isolate;
  overflow: hidden;
}

.background {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background:
    linear-gradient(90deg, rgba(248, 241, 231, 0.98) 0%, rgba(248, 241, 231, 0.9) 52%, rgba(248, 241, 231, 0.28) 100%),
    repeating-linear-gradient(
      0deg,
      rgba(50, 47, 42, 0.032) 0,
      rgba(50, 47, 42, 0.032) 1px,
      transparent 1px,
      transparent 34px
    ),
    repeating-linear-gradient(
      90deg,
      rgba(50, 47, 42, 0.024) 0,
      rgba(50, 47, 42, 0.024) 1px,
      transparent 1px,
      transparent 42px
    );
}

.gridSeal {
  position: absolute;
  right: 10%;
  top: 48%;
  width: 72px;
  height: 72px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  border: 1px solid rgba(139, 72, 49, 0.25);
  color: rgba(139, 72, 49, 0.48);
  font-family: Georgia, serif;
  font-size: 28px;
  font-weight: 800;
  transform: rotate(-12deg);
}

.landLineOne,
.landLineTwo {
  position: absolute;
  right: -16%;
  width: 70%;
  height: 1px;
  background: rgba(139, 72, 49, 0.12);
}

.landLineOne {
  top: 38%;
  transform: rotate(32deg);
}

.landLineTwo {
  top: 65%;
  transform: rotate(-18deg);
}

.topBar {
  position: relative;
  z-index: 5;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 18px 20px 0;
  padding: 17px 19px;
  border-radius: 28px;
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-shadow: 0 18px 48px rgba(61, 50, 39, 0.08);
}

.brand strong {
  display: block;
  font-size: 20px;
  line-height: 1.15;
  letter-spacing: -0.06em;
}

.brand span {
  display: block;
  margin-top: 7px;
  color: rgba(50, 47, 42, 0.64);
  font-size: 12px;
  letter-spacing: -0.03em;
}

.menuButton {
  width: 46px;
  height: 46px;
  display: grid;
  place-items: center;
  padding: 10px;
  border: 1px solid transparent;
  border-radius: 15px;
  background: rgba(255, 255, 255, 0.18);
  cursor: pointer;
}

.menuButton span {
  width: 28px;
  height: 2px;
  background: rgba(50, 47, 42, 0.76);
  border-radius: 999px;
}

.menuButtonOpen {
  border-color: rgba(139, 72, 49, 0.26);
  background: rgba(255, 255, 255, 0.7);
}

.copy {
  position: relative;
  z-index: 2;
  margin: 48px 28px 0;
  max-width: 322px;
}

.eyebrow {
  margin: 0 0 13px;
  color: rgba(50, 47, 42, 0.68);
  font-size: 14px;
  line-height: 1.35;
  font-weight: 850;
  letter-spacing: -0.05em;
}

.copy h1 {
  margin: 0;
  font-family: "Noto Serif KR", "Apple SD Gothic Neo", serif;
  font-size: 40px;
  line-height: 1.2;
  letter-spacing: -0.09em;
  font-weight: 650;
  color: #322f2a;
}

.subtitle {
  margin: 18px 0 0;
  max-width: 306px;
  color: rgba(50, 47, 42, 0.82);
  font-size: 15px;
  line-height: 1.62;
  letter-spacing: -0.05em;
  font-weight: 650;
  word-break: keep-all;
}

.actions {
  display: grid;
  gap: 11px;
  width: min(100%, 260px);
  margin-top: 22px;
}

.primary,
.secondary {
  min-height: 52px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 22px;
  border-radius: 999px;
  text-decoration: none;
  font-size: 16px;
  font-weight: 850;
  letter-spacing: -0.05em;
  cursor: pointer;
}

.primary {
  color: #322f2a;
  background: linear-gradient(90deg, #dceef9 0%, #f4f8fb 100%);
  border: 1px solid rgba(255, 255, 255, 0.96);
  box-shadow: 0 10px 28px rgba(92, 136, 160, 0.13);
}

.secondary {
  color: rgba(50, 47, 42, 0.72);
  background: rgba(255, 255, 255, 0.64);
  border: 1px solid rgba(255, 255, 255, 0.92);
  border-width: 1px;
}

.miniProof {
  position: relative;
  z-index: 2;
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin: 19px 24px 0;
}

.miniProof button {
  min-height: 32px;
  padding: 0 11px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.88);
  color: rgba(50, 47, 42, 0.72);
  background: rgba(255, 255, 255, 0.52);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: -0.04em;
  cursor: pointer;
}

.cards {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 13px;
  margin: 19px 22px 0;
}

.card {
  min-height: 106px;
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.9);
  border-radius: 20px;
  padding: 16px;
  color: #fffaf4;
  text-align: left;
  box-shadow: 0 14px 36px rgba(60, 51, 42, 0.1);
  cursor: pointer;
}

.rightsCard {
  background:
    linear-gradient(180deg, rgba(80, 72, 62, 0.08) 0%, rgba(80, 72, 62, 0.58) 100%),
    radial-gradient(circle at 34% 28%, rgba(255, 255, 255, 0.7), transparent 38%),
    linear-gradient(135deg, #d8c7b1, #a78366);
}

.visitCard {
  background:
    linear-gradient(180deg, rgba(80, 72, 62, 0.08) 0%, rgba(80, 72, 62, 0.52) 100%),
    radial-gradient(circle at 70% 24%, rgba(255, 255, 255, 0.72), transparent 42%),
    linear-gradient(135deg, #e3d7c5, #ad8b70);
}

.card small {
  display: block;
  color: rgba(255, 250, 244, 0.82);
  font-size: 10px;
  letter-spacing: 0.08em;
  font-weight: 800;
}

.card strong {
  display: block;
  margin-top: 35px;
  font-size: 19px;
  font-weight: 850;
  letter-spacing: -0.06em;
}

.card span {
  position: absolute;
  right: 14px;
  bottom: 14px;
  display: grid;
  place-items: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.82);
  color: #322f2a;
  font-size: 19px;
}

.phoneBar {
  position: relative;
  z-index: 2;
  min-height: 56px;
  display: grid;
  grid-template-columns: 1fr 1px 1fr;
  align-items: center;
  gap: 12px;
  margin: 18px 22px 0;
  padding: 0 16px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.58);
  border: 1px solid rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.phoneBar a,
.phoneBar button {
  color: rgba(50, 47, 42, 0.8);
  text-decoration: none;
  font-size: 14px;
  font-weight: 850;
  letter-spacing: -0.04em;
  background: none;
  border: 0;
  padding: 0;
  cursor: pointer;
}

.phoneBar i {
  height: 24px;
  background: rgba(50, 47, 42, 0.18);
}

.overlay {
  position: fixed;
  z-index: 1000;
  inset: 0;
  display: grid;
  align-items: end;
  justify-items: center;
  padding: 18px;
}

.overlayDim {
  position: absolute;
  inset: 0;
  border: 0;
  background: rgba(44, 48, 50, 0.3);
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
  cursor: pointer;
}

.menuScreen,
.panelScreen {
  position: relative;
  z-index: 1;
  width: min(100%, 430px);
  border-radius: 30px;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 24px 70px rgba(30, 30, 30, 0.22);
}

.menuScreen {
  padding: 24px 18px 18px;
}

.menuHead p,
.panelScreen p {
  margin: 0 0 7px;
  color: rgba(139, 72, 49, 0.72);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.08em;
}

.menuHead h2,
.panelScreen h2 {
  margin: 0 0 16px;
  color: #322f2a;
  font-size: 24px;
  line-height: 1.18;
  letter-spacing: -0.07em;
}

.menuList {
  display: grid;
  gap: 10px;
}

.menuList button {
  display: grid;
  gap: 5px;
  min-height: 64px;
  padding: 13px 15px;
  border-radius: 18px;
  border: 1px solid rgba(50, 47, 42, 0.08);
  background: #fffaf4;
  text-align: left;
  color: #322f2a;
  cursor: pointer;
}

.menuList strong {
  font-size: 16px;
  letter-spacing: -0.05em;
}

.menuList span {
  color: rgba(50, 47, 42, 0.65);
  font-size: 13px;
  line-height: 1.35;
  font-weight: 650;
  letter-spacing: -0.04em;
}

.panelScreen {
  max-height: min(72svh, 640px);
  overflow: auto;
  padding: 28px 22px 22px;
}

.close {
  position: absolute;
  top: 13px;
  right: 16px;
  width: 34px;
  height: 34px;
  border: 0;
  border-radius: 50%;
  background: rgba(50, 47, 42, 0.08);
  color: #322f2a;
  font-size: 24px;
  cursor: pointer;
}

.panelScreen ul {
  margin: 0;
  padding-left: 20px;
  color: rgba(50, 47, 42, 0.78);
  line-height: 1.75;
  font-size: 15px;
  font-weight: 650;
}

.panelAction {
  min-height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 22px;
  border-radius: 999px;
  background: #322f2a;
  color: #fffaf4;
  text-decoration: none;
  font-weight: 850;
}

@media (max-width: 380px) {
  .topBar {
    margin: 16px 16px 0;
  }

  .copy {
    margin: 36px 22px 0;
  }

  .copy h1 {
    font-size: 36px;
  }

  .subtitle {
    font-size: 14px;
  }

  .actions {
    width: 230px;
  }

  .cards,
  .miniProof,
  .phoneBar {
    margin-left: 16px;
    margin-right: 16px;
  }

  .card {
    min-height: 100px;
  }
}

@media (min-width: 431px) {
  .shell {
    padding: 16px 0;
  }

  .hero {
    min-height: calc(100svh - 32px);
  }
}
